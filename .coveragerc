[run]
omit =   
    # Все __init__.py
    */__init__.py
    
    # Конфигурационные файлы
    */config.py
    */settings.py
    */.env.py
    
    # Файлы запуска
    */main.py
    */manage.py
    */run.py
    
    # Миграции БД
    */migrations/*
    
    # Виртуальные окружения
    */venv/*
    */.venv/*
    */env/*
    
    # Сборка
    */build/*
    */dist/*
    */.eggs/*
    
    # Кэш
    */__pycache__/*
    *.pyc
    *.pyo
    
    # Документация
    */docs/*
    
    # Скрипты
    scripts/*
    */scripts/*